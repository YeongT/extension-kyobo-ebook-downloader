{
  "manifest_version": 3,
  "name": "Kyobo eBook PDF Downloader",
  "version": "3.0.0",
  "description": "교보 전자도서관 ebook 뷰어에서 PDF로 다운로드 + 리더",
  "permissions": ["storage", "activeTab", "tabs", "notifications"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://wviewer.kyobobook.co.kr/*"],
      "js": ["inject.js"],
      "world": "MAIN",
      "all_frames": false,
      "run_at": "document_start"
    },
    {
      "matches": ["https://wviewer.kyobobook.co.kr/*"],
      "js": [
        "content/content-overlay.js",
        "content/content-capture.js",
        "content/content-recovery.js",
        "content/content-passive.js",
        "content/content.js"
      ],
      "all_frames": false,
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.dkyobobook.co.kr/*"],
      "js": ["shared/cache-db.js", "shared/utils.js", "library.js"],
      "all_frames": false,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "CAU 교보 ebook PDF 다운로더",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/jspdf.umd.min.js", "lib/jszip.min.js", "assets/merge_pdf.py", "assets/merge_pdf.bat"],
      "matches": ["https://wviewer.kyobobook.co.kr/*"]
    }
  ]
}
